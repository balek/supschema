{
  "name": "@supschema/ts-infer",
  "version": "0.0.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "subschema-dev": "./index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "subschema-dev": "./*",
      "default": "./dist/*"
    }
  },
  "dependencies": {
    "@supschema/core": "workspace:*"
  },
  "optionalDependencies": {
    "@supschema/common-types": "workspace:*"
  },
  "author": "Alexey Balekhov <alexeybalekhov@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/balek/supschema.git"
  },
  "license": "MIT"
}
